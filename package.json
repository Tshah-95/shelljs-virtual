{
  "name": "shelljs-virtual",
  "version": "0.1.0",
  "description": "A memfs-compatible virtual shell inspired by ShellJS.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "shelljs",
    "virtual-fs",
    "memfs",
    "agent-tools",
    "code-search"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "lint": "bun run scripts/lint.ts",
    "check": "bun x tsc --noEmit",
    "test": "bun test",
    "test:phase1": "bun test tests/phase1.test.ts",
    "test:phase2": "bun test tests/phase2.test.ts",
    "test:phase3": "bun test tests/phase3.test.ts",
    "test:phase45": "bun test tests/phase45.test.ts",
    "test:integration": "bun test tests/integration.test.ts",
    "verify": "bun run lint && bun run check && bun test && bun run build"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/node": "^20.17.57",
    "bun-types": "^1.3.12",
    "eslint": "^9.37.0",
    "memfs": "^4.17.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
